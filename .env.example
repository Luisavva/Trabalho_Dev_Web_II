# ──────────────────────────────────────────────────────────────
# String de conexão do SQLite usada pelo adapter (em runtime).
# O adapter better-sqlite3 resolve o caminho a partir da RAIZ do
# projeto, por isso o caminho inclui "prisma/".
# ──────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# Segredo usado para assinar os tokens JWT.
# Em produção troque por uma string longa e aleatória.
JWT_SECRET="troque-este-valor-por-uma-string-aleatoria-bem-grande"

# Tempo de expiração do token (ex.: 1d, 12h, 3600)
JWT_EXPIRES_IN="1d"

# Porta do servidor HTTP
PORT=3333
